#!/usr/bin/env bash
set -euo pipefail

pattern="${1:-}"
shift || true

if [[ -z "$pattern" ]]; then
  echo "Usage: trackrec-run <pattern> [--listen] [--out <dir>] [--min-seconds <n>] [--comp <0-8>] [--format <flac|mp3>] [--mp3-bitrate <rate>] [--player <name>] [--no-follow] [--follow-interval <sec>] [--no-dedupe]"
  exit 1
fi

# ---- Load defaults from config (optional) ----
CFG_FILE="$HOME/.config/trackrec/trackrec.conf"
if [[ -f "$CFG_FILE" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^# ]] && continue
    if [[ "$line" =~ ^TRACKREC_[A-Z0-9_]+= ]]; then
      eval "$line"
    fi
  done < "$CFG_FILE"
fi

# ---- Defaults (config provides defaults; CLI flags override) ----
PLAYER="$pattern"
OUTDIR="${TRACKREC_OUTDIR:-$HOME/recordings}"
MIN_SECONDS="${TRACKREC_MIN_SECONDS:-30}"
COMP="${TRACKREC_COMP:-5}"
FORMAT="${TRACKREC_FORMAT:-flac}"
MP3_BITRATE="${TRACKREC_MP3_BITRATE:-320k}"
LISTEN="${TRACKREC_LISTEN:-0}"

FOLLOW="${TRACKREC_FOLLOW:-1}"
FOLLOW_INTERVAL="${TRACKREC_FOLLOW_INTERVAL:-1}"

DEDUPE="${TRACKREC_DEDUPE:-1}"   # default ON

while [[ $# -gt 0 ]]; do
  case "$1" in
    --player) PLAYER="${2:-$PLAYER}"; shift 2;;
    --out) OUTDIR="${2:-$OUTDIR}"; shift 2;;
    --min-seconds) MIN_SECONDS="${2:-$MIN_SECONDS}"; shift 2;;
    --comp) COMP="${2:-$COMP}"; shift 2;;
    --format) FORMAT="${2:-$FORMAT}"; shift 2;;
    --mp3-bitrate) MP3_BITRATE="${2:-$MP3_BITRATE}"; shift 2;;
    --listen) LISTEN=1; shift;;
    --no-follow) FOLLOW=0; shift;;
    --follow-interval) FOLLOW_INTERVAL="${2:-$FOLLOW_INTERVAL}"; shift 2;;
    --no-dedupe) DEDUPE=0; shift;;
    *) echo "Unknown option: $1"; exit 2;;
  esac
done

case "$FORMAT" in
  flac|mp3) ;;
  *) echo "ERROR: unsupported format '$FORMAT' (use flac or mp3)" >&2; exit 2;;
esac

RECORDER="$HOME/.local/bin/trackrec/trackrec-recorder.py"

if [[ ! -x "$RECORDER" ]]; then
  if [[ -x "$(dirname "$0")/trackrec-recorder.py" ]]; then
    RECORDER="$(dirname "$0")/trackrec-recorder.py"
  else
    echo "Missing internal recorder: trackrec-recorder.py" >&2
    exit 3
  fi
fi

for cmd in trackrec-setup pactl trackrec-listen-on trackrec-listen-off; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "Missing command: $cmd"; exit 3; }
done

STATE_DIR="/run/user/$(id -u)/trackrec-run"
MAP_FILE="$STATE_DIR/moved-streams.tsv"     # stream_id \t orig_sink_id
SEEN_FILE="$STATE_DIR/seen-streams.txt"     # stream_ids we already processed
mkdir -p "$STATE_DIR"
: > "$MAP_FILE"
: > "$SEEN_FILE"

cleanup() {
  set +e

  [[ "$LISTEN" -eq 1 ]] && trackrec-listen-off >/dev/null 2>&1 || true

  if [[ -n "${FOLLOW_PID:-}" ]]; then
    kill "$FOLLOW_PID" >/dev/null 2>&1 || true
    wait "$FOLLOW_PID" >/dev/null 2>&1 || true
  fi

  if [[ -s "$MAP_FILE" ]]; then
    while IFS=$'\t' read -r sid orig_sink; do
      pactl move-sink-input "$sid" "$orig_sink" >/dev/null 2>&1 || true
    done < "$MAP_FILE"
  fi

  rm -rf "$STATE_DIR" >/dev/null 2>&1 || true
}
trap cleanup EXIT INT TERM

trackrec-setup

pat_lc="$(echo "$pattern" | tr '[:upper:]' '[:lower:]')"

match_and_move_new_streams() {
  local ids id block orig_sink app bin media hay
  ids="$(pactl list short sink-inputs | awk '{print $1}' || true)"
  [[ -z "$ids" ]] && return 0

  for id in $ids; do
    if grep -qx "$id" "$SEEN_FILE" 2>/dev/null; then
      continue
    fi

    block="$(pactl list sink-inputs | sed -n "/Sink Input #$id\b/,/^$/p")"
    orig_sink="$(echo "$block" | sed -n 's/^[[:space:]]*Sink: \([0-9]\+\).*/\1/p' | head -n1)"
    [[ -z "$orig_sink" ]] && { echo "$id" >> "$SEEN_FILE"; continue; }

    app="$(echo "$block" | sed -n 's/^[[:space:]]*application\.name = "\(.*\)".*/\1/p' | head -n1)"
    bin="$(echo "$block" | sed -n 's/^[[:space:]]*application\.process\.binary = "\(.*\)".*/\1/p' | head -n1)"
    media="$(echo "$block" | sed -n 's/^[[:space:]]*media\.name = "\(.*\)".*/\1/p' | head -n1)"

    hay="$(printf "%s\n%s\n%s\n" "$app" "$bin" "$media" | tr '[:upper:]' '[:lower:]')"

    if echo "$hay" | grep -qF "$pat_lc"; then
      if pactl move-sink-input "$id" rec >/dev/null 2>&1; then
        printf "%s\t%s\n" "$id" "$orig_sink" >> "$MAP_FILE"
      else
        echo "Warning: failed to move sink-input #$id to rec" >&2
      fi
    fi

    echo "$id" >> "$SEEN_FILE"
  done
}

match_and_move_new_streams
if [[ ! -s "$MAP_FILE" ]]; then
  echo "No matching audio streams for '$pattern'. Start playback first."
  exit 4
fi

if [[ -z "$OUTDIR" ]]; then
  echo "ERROR: OUTDIR resolved to empty string"
  exit 5
fi

mkdir -p "$OUTDIR"

if [[ "$LISTEN" -eq 1 ]]; then
  trackrec-listen-on
  echo "Listen: ON"
else
  echo "Listen: OFF (silent capture)"
fi

if [[ "$FOLLOW" -eq 1 ]]; then
  (
    while true; do
      match_and_move_new_streams
      sleep "$FOLLOW_INTERVAL"
    done
  ) &
  FOLLOW_PID="$!"
  echo "Follow: ON (interval ${FOLLOW_INTERVAL}s)"
else
  echo "Follow: OFF"
fi

echo "Recording '$pattern' → $OUTDIR"
echo "Player: $PLAYER | min-seconds: $MIN_SECONDS | format: $FORMAT | dedupe: $([[ "$DEDUPE" -eq 1 ]] && echo ON || echo OFF)"

extra_args=()
if [[ "$FORMAT" == "flac" ]]; then
  extra_args+=(--comp "$COMP")
elif [[ "$FORMAT" == "mp3" ]]; then
  extra_args+=(--mp3-bitrate "$MP3_BITRATE")
fi

dedupe_args=()
if [[ "$DEDUPE" -eq 1 ]]; then
  dedupe_args+=(--dedupe)
fi

exec "$RECORDER" \
  --source rec.monitor \
  --out "$OUTDIR" \
  --player "$PLAYER" \
  --format "$FORMAT" \
  --min-seconds "$MIN_SECONDS" \
  "${extra_args[@]}" \
  "${dedupe_args[@]}"