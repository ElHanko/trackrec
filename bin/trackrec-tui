#!/usr/bin/env python3
from __future__ import annotations

import asyncio
import os
import time
from pathlib import Path
from typing import Optional

from textual.app import App, ComposeResult
from textual.widgets import Footer, Header, Static, Input

SCRIPT_PATH = Path(__file__).resolve()
SCRIPT_DIR = SCRIPT_PATH.parent
TRACKREC_RUN = SCRIPT_DIR / "trackrec-run"
TRACKREC_STOP = SCRIPT_DIR / "trackrec-stop"
TRACKREC_ENRICH = SCRIPT_DIR / "trackrec-enrich"
TRACKREC_STEM = SCRIPT_DIR / "trackrec-stem"

CONFIG_FILE = Path.home() / ".config" / "trackrec" / "trackrec.conf"
STATUS_FILE = Path(f"/run/user/{os.getuid()}/trackrec-run/recorder.status")


class TrackrecTUI(App):
    TITLE = "trackrec"

    BOOL_KEYS = {
        "TRACKREC_AUTOSKIP",
        "TRACKREC_DEDUPE",
        "TRACKREC_LISTEN",
        "TRACKREC_FOLLOW",
        "TRACKREC_FORCE_VOLUME",
        "TRACKREC_ENRICH_WRITE",
        "TRACKREC_ENRICH_FORCE",
        "TRACKREC_ENRICH_SET_YEAR",
        "TRACKREC_ENRICH_SET_DATE",
        "TRACKREC_ENRICH_SET_GENRE",
        "TRACKREC_ENRICH_DJ",
    }

    BINDINGS = [
        ("s", "start", "Start"),
        ("e", "enrich", "Enrich"),
        ("m", "stem", "Stem"),
        ("x", "stop", "Stop"),
        ("c", "config_view", "Config"),
        ("r", "reload", "Reload"),
        ("l", "clear", "Clear"),
        ("q", "quit", "Quit"),
    ]

    process: Optional[asyncio.subprocess.Process] = None
    read_output_task: Optional[asyncio.Task] = None
    owns_process: bool = False
    current_job: str = "idle"   # idle | record | enrich | stem
    log_lines: list[str] = []
    status: dict[str, str] = {}
    config: dict[str, str] = {}

    view: str = "main"          # main | config
    config_keys: list[str] = []
    config_index: int = 0

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)
        yield Static(id="main")
        yield Footer()

    async def on_mount(self) -> None:
        self.load_config()
        self.rebuild_config_keys()
        self.set_interval(1, self.refresh_view)
        self.refresh_view()

    async def on_unmount(self) -> None:
        if self.read_output_task and not self.read_output_task.done():
            self.read_output_task.cancel()

    def load_config(self) -> None:
        self.config = {}
        if CONFIG_FILE.exists():
            for raw_line in CONFIG_FILE.read_text(encoding="utf-8").splitlines():
                line = raw_line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                self.config[key.strip()] = value.strip().strip('"').strip("'")

    def rebuild_config_keys(self) -> None:
        preferred_order = [
            "TRACKREC_OUTDIR",
            "TRACKREC_FORMAT",
            "TRACKREC_COMP",
            "TRACKREC_MP3_BITRATE",
            "TRACKREC_SAMPLE_RATE",
            "TRACKREC_MIN_SECONDS",
            "TRACKREC_AUTOSKIP",
            "TRACKREC_AUTOSKIP_DELAY",
            "TRACKREC_LISTEN",
            "TRACKREC_FOLLOW",
            "TRACKREC_FOLLOW_INTERVAL",
            "TRACKREC_DEDUPE",
            "TRACKREC_FORCE_VOLUME",
            "TRACKREC_STEM_MODE",
            "TRACKREC_STEM_CMD",
            "TRACKREC_STEM_REMOTE_HOST",
            "TRACKREC_STEM_REMOTE_BASE",
        ]

        if self.enrich_enabled():
            preferred_order.extend([
                "TRACKREC_ENRICH_WRITE",
                "TRACKREC_ENRICH_FORCE",
                "TRACKREC_ENRICH_SET_YEAR",
                "TRACKREC_ENRICH_SET_DATE",
                "TRACKREC_ENRICH_SET_GENRE",
                "TRACKREC_ENRICH_DJ",
            ])

        preferred_order.append("TRACKREC_PLAYER")

        seen = set()
        keys: list[str] = []

        for key in preferred_order:
            if key in self.config:
                keys.append(key)
                seen.add(key)

        hidden_keys = {"TRACKREC_TUI_ENABLE_ENRICH"}

        for key in sorted(self.config.keys()):
            if key in hidden_keys:
                continue
            if key not in seen:
                keys.append(key)

        self.config_keys = keys
        if self.config_index >= len(self.config_keys):
            self.config_index = max(0, len(self.config_keys) - 1)

    def save_config(self) -> None:
        CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)

        lines = [
            "# trackrec defaults (saved by trackrec-tui)",
            "# CLI flags always override these values.",
            "",
        ]
        for key in self.config_keys:
            value = self.config.get(key, "")
            lines.append(f'{key}="{value}"')

        hidden_keys = {"TRACKREC_TUI_ENABLE_ENRICH"}
        for key in sorted(self.config.keys()):
            if key in hidden_keys:
                continue
            if key not in self.config_keys:
                value = self.config.get(key, "")
                lines.append(f'{key}="{value}"')

        CONFIG_FILE.write_text("\n".join(lines) + "\n", encoding="utf-8")
        self.log_line("config saved")

    def read_status(self) -> None:
        data: dict[str, str] = {}
        if STATUS_FILE.exists():
            for raw_line in STATUS_FILE.read_text(encoding="utf-8").splitlines():
                line = raw_line.strip()
                if not line or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                data[key.strip()] = value.strip()
        self.status = data

    def is_bool_key(self, key: str) -> bool:
        return key in self.BOOL_KEYS

    def toggle_bool_value(self, key: str) -> None:
        current = self.config.get(key, "0").strip()
        self.config[key] = "0" if current == "1" else "1"

    def enrich_enabled(self) -> bool:
        return self.config.get("TRACKREC_TUI_ENABLE_ENRICH", "0") == "1"
    
    def stem_enabled(self) -> bool:
        mode = self.config.get("TRACKREC_STEM_MODE", "off").strip().lower()
        cmd = self.config.get("TRACKREC_STEM_CMD", "").strip()
        return mode in {"local", "remote"} and bool(cmd)

    def on_off(self, value: Optional[str]) -> str:
        return "ON" if str(value or "0") == "1" else "OFF"

    def truncate(self, value: str, max_len: int = 70) -> str:
        value = value or "-"
        return value if len(value) <= max_len else value[: max_len - 3] + "..."

    def format_elapsed(self, started_at: Optional[str]) -> str:
        if not started_at or not started_at.isdigit():
            return "-"
        delta = max(0, int(time.time()) - int(started_at))
        hours = delta // 3600
        minutes = (delta % 3600) // 60
        seconds = delta % 60
        if hours > 0:
            return f"{hours:02d}:{minutes:02d}:{seconds:02d}"
        return f"{minutes:02d}:{seconds:02d}"

    def format_line(self) -> str:
        fmt = self.config.get("TRACKREC_FORMAT", "-")
        sample_rate = self.config.get("TRACKREC_SAMPLE_RATE", "-")
        if fmt != "-" and sample_rate != "-":
            return f"{fmt} @ {sample_rate} Hz"
        return "-"

    def autoskip_line(self) -> str:
        enabled = self.on_off(self.status.get("AUTOSKIP") or self.config.get("TRACKREC_AUTOSKIP"))
        delay = self.status.get("AUTOSKIP_DELAY") or self.config.get("TRACKREC_AUTOSKIP_DELAY") or "-"
        pending = self.status.get("AUTOSKIP_PENDING", "0") == "1"

        if enabled == "OFF":
            return "OFF"
        if pending:
            return f"ON ({delay}s, pending)"
        return f"ON ({delay}s)"

    def control_line(self) -> str:
        return "OWNED" if self.owns_process else "EXTERNAL"

    def job_line(self) -> str:
        return self.current_job.upper()

    def render_main(self) -> str:
        s = self.status
        c = self.config
        lines: list[str] = []

        lines.append(f"STATE     {s.get('STATE', 'idle').upper()}")
        lines.append(f"JOB       {self.job_line()}")
        lines.append(f"PLAYER    {c.get('TRACKREC_PLAYER', 'spotify')}")
        lines.append("SOURCE    rec.monitor")
        lines.append(f"FORMAT    {self.format_line()}")
        lines.append(f"DEDUPE    {self.on_off(c.get('TRACKREC_DEDUPE'))}")
        lines.append(f"AUTOSKIP  {self.autoskip_line()}")
        lines.append(f"CONTROL   {self.control_line()}")
        lines.append(f"OUTDIR    {self.truncate(c.get('TRACKREC_OUTDIR', '-'), 58)}")
        lines.append("")

        state = s.get("STATE", "").lower()
        artist = s.get("ARTIST", "").strip()
        title = s.get("TITLE", "").strip()
        now_line = f"{artist} - {title}".strip(" -")

        if state in {"recording", "skipped"} and now_line:
            lines.append(f"NOW       {self.truncate(now_line, 58)}")

        file_value = s.get("FILE", "").strip()
        if file_value:
            lines.append(f"FILE      {self.truncate(file_value, 58)}")

        elapsed = self.format_elapsed(s.get("STARTED_AT"))
        if state == "recording" and elapsed != "-":
            lines.append(f"ELAPSED   {elapsed}")

        lines.append("")

        last_result = s.get("LAST_RESULT", "").strip()
        last_duration = s.get("LAST_DURATION", "").strip()
        last_file = s.get("LAST_FILE", "").strip()

        if last_result or last_duration or last_file:
            duration_part = f"{last_duration}s" if last_duration else "-"
            file_part = self.truncate(last_file, 40) if last_file else "-"
            lines.append(f"LAST      {last_result or '-'} | {duration_part} | {file_part}")
        else:
            lines.append("LAST      (none)")

        lines.append("")
        lines.append("LOG")

        if not self.log_lines:
            lines.append("(no live output in this session)")
        else:
            for line in self.log_lines[-10:]:
                lines.append(self.truncate(line, 70))

        return "\n".join(lines)

    def render_config(self) -> str:
        lines = ["CONFIG", ""]

        if not self.config_keys:
            lines.append("(no config values loaded)")
        else:
            for i, key in enumerate(self.config_keys):
                prefix = ">" if i == self.config_index else " "
                value = self.config.get(key, "")
                if self.is_bool_key(key):
                    value = self.on_off(value)
                lines.append(f"{prefix} {key:<24} {self.truncate(value, 40)}")

        lines.append("")
        lines.append("up/down: select   enter/space: toggle bool   s: save   q: back")
        lines.append("non-boolean editing not implemented yet")
        return "\n".join(lines)

    def render_view(self) -> str:
        if self.view == "config":
            return self.render_config()
        return self.render_main()

    def refresh_view(self) -> None:
        self.read_status()
        self.query_one("#main", Static).update(self.render_view())

    def log_line(self, msg: str) -> None:
        self.log_lines.append(msg)
        self.refresh_view()

    async def action_start(self) -> None:
        if self.view != "main":
            return
        if self.process and self.process.returncode is None:
            self.log_line("another job is already running")
            return

        player = self.config.get("TRACKREC_PLAYER", "spotify")
        cmd = [str(TRACKREC_RUN), player]
        self.log_line(f"$ {' '.join(cmd)}")

        self.process = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.STDOUT,
        )

        self.owns_process = True
        self.current_job = "record"
        self.read_output_task = asyncio.create_task(self.read_output())

    async def action_enrich(self) -> None:
        if self.view != "main":
            return

        if not self.enrich_enabled():
            self.log_line("enrich is disabled in this installation")
            return

        if self.process and self.process.returncode is None:
            self.log_line("another job is already running")
            return

        if not TRACKREC_ENRICH.exists():
            self.log_line("trackrec-enrich is not installed")
            return

        outdir = self.config.get("TRACKREC_OUTDIR", str(Path.home() / "recordings"))
        cmd = [str(TRACKREC_ENRICH), outdir]

        if self.config.get("TRACKREC_ENRICH_WRITE", "0") == "1":
            cmd.append("--write")

        if self.config.get("TRACKREC_ENRICH_FORCE", "0") == "1":
            cmd.append("--force")

        if self.config.get("TRACKREC_ENRICH_SET_YEAR", "0") == "1":
            cmd.append("--set-year")

        if self.config.get("TRACKREC_ENRICH_SET_DATE", "0") == "1":
            cmd.append("--set-date")

        if self.config.get("TRACKREC_ENRICH_SET_GENRE", "0") == "1":
            cmd.append("--set-genre")

        if self.config.get("TRACKREC_ENRICH_DJ", "0") == "1":
            cmd.append("--dj")

        self.log_line(f"$ {' '.join(cmd)}")

        self.process = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.STDOUT,
        )

        self.owns_process = True
        self.current_job = "enrich"
        self.read_output_task = asyncio.create_task(self.read_output())

    async def action_stem(self) -> None:
        if self.view != "main":
            return

        if not self.stem_enabled():
            self.log_line("stem is not configured")
            return

        if self.process and self.process.returncode is None:
            self.log_line("another job is already running")
            return

        if not TRACKREC_STEM.exists():
            self.log_line("trackrec-stem is not installed")
            return

        outdir = self.config.get("TRACKREC_OUTDIR", str(Path.home() / "recordings"))
        cmd = [str(TRACKREC_STEM), outdir]

        self.log_line(f"$ {' '.join(cmd)}")

        self.process = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.STDOUT,
        )

        self.owns_process = True
        self.current_job = "stem"
        self.read_output_task = asyncio.create_task(self.read_output())

    async def read_output(self) -> None:
        if not self.process or not self.process.stdout:
            return

        try:
            while True:
                line = await self.process.stdout.readline()
                if not line:
                    break
                self.log_line(line.decode(errors="replace").strip())
        except asyncio.CancelledError:
            return
        finally:
            if self.process:
                rc = await self.process.wait()
                if self.current_job == "record":
                    self.log_line(f"trackrec-run exited with code {rc}")
                elif self.current_job == "enrich":
                    self.log_line(f"trackrec-enrich exited with code {rc}")
                elif self.current_job == "stem":
                    self.log_line(f"trackrec-stem exited with code {rc}")
                else:
                    self.log_line(f"job exited with code {rc}")
                self.process = None
                self.owns_process = False
                self.current_job = "idle"
                self.refresh_view()

    async def action_stop(self) -> None:
        if self.view != "main":
            return

        if self.current_job in {"enrich", "stem"}:
            self.log_line("stop only applies to recording jobs")
            return

        self.log_line(f"$ {TRACKREC_STOP}")
        proc = await asyncio.create_subprocess_exec(
            str(TRACKREC_STOP),
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.STDOUT,
        )

        try:
            stdout, _ = await asyncio.wait_for(proc.communicate(), timeout=3)
            if stdout:
                for line in stdout.decode(errors="replace").splitlines():
                    self.log_line(line.strip())
        except asyncio.TimeoutError:
            self.log_line("trackrec-stop timed out")
            return

        if self.process and self.process.returncode is None:
            try:
                rc = await asyncio.wait_for(self.process.wait(), timeout=3)
                self.log_line(f"trackrec-run exited with code {rc}")
            except asyncio.TimeoutError:
                self.log_line("trackrec-run did not exit after stop")
                return

        self.process = None
        self.owns_process = False
        self.current_job = "idle"
        self.refresh_view()

    async def action_config_view(self) -> None:
        self.view = "config"
        self.rebuild_config_keys()
        self.refresh_view()

    async def action_reload(self) -> None:
        self.load_config()
        self.rebuild_config_keys()
        self.log_line("config reloaded")
        self.refresh_view()

    async def action_clear(self) -> None:
        if self.view != "main":
            return
        self.log_lines.clear()
        self.refresh_view()

    async def edit_current_config(self) -> None:
        if not self.config_keys:
            return

        key = self.config_keys[self.config_index]
        if self.is_bool_key(key):
            return

        current_value = self.config.get(key, "")

        input_widget = Input(value=current_value, placeholder=key)
        await self.push_screen_wait(input_widget)  # likely unsupported for plain Input
        # Fallback below if needed

    async def on_key(self, event) -> None:
        if self.view != "config":
            return

        if not self.config_keys:
            if event.key == "q":
                self.view = "main"
                self.refresh_view()
            return

        if event.key == "up":
            self.config_index = max(0, self.config_index - 1)
            self.refresh_view()
            event.prevent_default()
            return

        if event.key == "down":
            self.config_index = min(len(self.config_keys) - 1, self.config_index + 1)
            self.refresh_view()
            event.prevent_default()
            return

        if event.key in ("enter", "space"):
            key = self.config_keys[self.config_index]
            if self.is_bool_key(key):
                self.toggle_bool_value(key)
                self.refresh_view()
            event.prevent_default()
            return

        if event.key == "e":
            key = self.config_keys[self.config_index]
            if not self.is_bool_key(key):
                current_value = self.config.get(key, "")
                new_value = await self.prompt_edit_value(key, current_value)
                if new_value is not None:
                    self.config[key] = new_value
                    self.refresh_view()
            event.prevent_default()
            return

        if event.key == "s":
            self.save_config()
            self.refresh_view()
            event.prevent_default()
            return

        if event.key == "q":
            self.view = "main"
            self.refresh_view()
            event.prevent_default()
            return

    async def prompt_edit_value(self, key: str, current_value: str) -> Optional[str]:
        return None

    async def action_quit(self) -> None:
        if self.view == "config":
            self.view = "main"
            self.refresh_view()
            return

        if self.owns_process and self.current_job == "record":
            self.log_line("stopping owned trackrec-run before exit...")
            try:
                proc = await asyncio.create_subprocess_exec(
                    str(TRACKREC_STOP),
                    stdout=asyncio.subprocess.PIPE,
                    stderr=asyncio.subprocess.STDOUT,
                )
                stdout, _ = await asyncio.wait_for(proc.communicate(), timeout=3)
                if stdout:
                    for line in stdout.decode(errors="replace").splitlines():
                        self.log_line(line.strip())
            except asyncio.TimeoutError:
                self.log_line("trackrec-stop timed out on exit")
            except Exception as e:
                self.log_line(f"stop on exit failed: {e}")

            self.owns_process = False
            self.current_job = "idle"

        if self.read_output_task and not self.read_output_task.done():
            self.read_output_task.cancel()
            try:
                await asyncio.wait_for(self.read_output_task, timeout=1)
            except asyncio.TimeoutError:
                self.log_line("read_output task did not stop cleanly")
            except asyncio.CancelledError:
                pass
            except Exception as e:
                self.log_line(f"read_output cleanup failed: {e}")

        self.exit()


if __name__ == "__main__":
    TrackrecTUI().run()