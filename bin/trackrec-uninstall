#!/usr/bin/env bash
set -euo pipefail

BIN_DST="$HOME/.local/bin"

CORE_TOOLS=(
  trackrec-recorder.py
  trackrec-listen-off
  trackrec-listen-on
  trackrec-route
  trackrec-run
  trackrec-setup
  trackrec-status
  trackrec-stop
  trackrec-uninstall
)

ENRICH_TOOLS=(
  trackrec-enrich
  spotify_apply_tags.py
)

echo "Removing trackrec commands from $BIN_DST ..."

for name in "${CORE_TOOLS[@]}" "${ENRICH_TOOLS[@]}"; do
  if [[ -e "$BIN_DST/$name" ]]; then
    rm -f "$BIN_DST/$name"
    echo "  -> removed $name"
  fi
done

echo
echo "trackrec commands removed."

echo
echo "Config files were NOT removed:"
echo "  ~/.config/trackrec/trackrec.conf"
echo "  ~/.config/trackrec/.env"

echo
echo "If you want a full wipe:"
echo "  rm -rf ~/.config/trackrec"