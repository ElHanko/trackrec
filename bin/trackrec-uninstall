#!/usr/bin/env bash
set -euo pipefail

BIN_DST="$HOME/.local/bin"
APP_DIR="$BIN_DST/trackrec"

CORE_TOOLS=(
  trackrec-recorder.py
  trackrec-listen-off
  trackrec-listen-on
  trackrec-normalize
  trackrec-route
  trackrec-run
  trackrec-setup
  trackrec-status
  trackrec-stop
  trackrec-uninstall
)

ENRICH_TOOLS=(
  trackrec-enrich
  trackrec-enrich-spot
  trackrec-enrich-spot.py
)

ALL_TOOLS=("${CORE_TOOLS[@]}" "${ENRICH_TOOLS[@]}")

echo "Removing trackrec command wrappers from $BIN_DST ..."
for name in "${ALL_TOOLS[@]}"; do
  if [[ -e "$BIN_DST/$name" ]]; then
    rm -f "$BIN_DST/$name"
    echo "  -> removed wrapper $name"
  fi
done

echo
echo "Removing trackrec files from $APP_DIR ..."
for name in "${ALL_TOOLS[@]}"; do
  if [[ -e "$APP_DIR/$name" ]]; then
    rm -f "$APP_DIR/$name"
    echo "  -> removed file $name"
  fi
done

rmdir "$APP_DIR" 2>/dev/null || true

echo
echo "trackrec commands removed."

echo
echo "Removing trackrec launcher scripts ..."
LAUNCHER_DIR="$HOME/.local/bin/trackrec-launcher"

if [[ -d "$LAUNCHER_DIR" ]]; then
  rm -rf "$LAUNCHER_DIR"
  echo "  -> removed $LAUNCHER_DIR"
fi

echo
echo "Removing trackrec desktop entries ..."
APP_DESKTOP_DIR="$HOME/.local/share/applications"

shopt -s nullglob
for f in "$APP_DESKTOP_DIR"/trackrec-*.desktop; do
  rm -f "$f"
  echo "  -> removed $(basename "$f")"
done
shopt -u nullglob

MENU_DIR="$HOME/.config/menus/applications-merged"
DIR_DIR="$HOME/.local/share/desktop-directories"

rm -f "$MENU_DIR/trackrec.menu"
rm -f "$DIR_DIR/trackrec.directory"

echo
echo "Config files were NOT removed:"
echo "  ~/.config/trackrec/trackrec.conf"
echo "  ~/.config/trackrec/.env"

echo
echo "If you want a full wipe:"
echo "  rm -rf ~/.config/trackrec"