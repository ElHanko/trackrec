#!/usr/bin/env bash
set -euo pipefail

BIN_DST="$HOME/.local/bin"
APP_DIR="$BIN_DST/trackrec"

CORE_TOOLS=(
  trackrec-recorder.py
  trackrec-listen-off
  trackrec-listen-on
  trackrec-route
  trackrec-run
  trackrec-setup
  trackrec-status
  trackrec-stop
  trackrec-uninstall
)

ENRICH_TOOLS=(
  trackrec-enrich
  trackrec-enrich-spot
  trackrec-enrich-spot.py
)

ALL_TOOLS=("${CORE_TOOLS[@]}" "${ENRICH_TOOLS[@]}")

echo "Removing trackrec command wrappers from $BIN_DST ..."
for name in "${ALL_TOOLS[@]}"; do
  if [[ -e "$BIN_DST/$name" ]]; then
    rm -f "$BIN_DST/$name"
    echo "  -> removed wrapper $name"
  fi
done

echo
echo "Removing trackrec files from $APP_DIR ..."
for name in "${ALL_TOOLS[@]}"; do
  if [[ -e "$APP_DIR/$name" ]]; then
    rm -f "$APP_DIR/$name"
    echo "  -> removed file $name"
  fi
done

rmdir "$APP_DIR" 2>/dev/null || true

echo
echo "trackrec commands removed."

echo
echo "Config files were NOT removed:"
echo "  ~/.config/trackrec/trackrec.conf"
echo "  ~/.config/trackrec/.env"

echo
echo "If you want a full wipe:"
echo "  rm -rf ~/.config/trackrec"