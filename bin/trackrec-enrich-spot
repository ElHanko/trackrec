#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  trackrec-enrich [<path...>] [options]

If no <path> is given, trackrec-enrich uses TRACKREC_OUTDIR from:
  ~/.config/trackrec/trackrec.conf
Fallback:
  $HOME/recordings

Examples:
  trackrec-enrich --write
  trackrec-enrich --write --set-year
  trackrec-enrich "$HOME/recordings/Artist - Track.flac" --write --force

Notes:
- Reads SPOTIFY_URL from files and enriches tags via Spotify Web API.
- Needs SPOTIFY_CLIENT_ID and SPOTIFY_CLIENT_SECRET (env) unless passed via flags.
- Batch mode: token is fetched once and reused.

Options are forwarded to the tagger:
  --spotify-client-id <id>
  --spotify-client-secret <secret>
  --write
  --force
  --set-year
  --set-date
  --set-genre
  --dump
  --quiet
  --max-retries <n>
  --sleep <seconds>
USAGE
}

need_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "Missing command: $1" >&2; exit 3; }; }

# Load .env if present (project-local or HOME)
load_env() {
  local f
  for f in ".env" "$HOME/.config/trackrec/.env"; do
    if [[ -f "$f" ]]; then
      set -a
      # shellcheck disable=SC1090
      source "$f"
      set +a
      return 0
    fi
  done
  return 0
}

# Load TRACKREC_* defaults from config (optional)
load_trackrec_conf() {
  local cfg="$HOME/.config/trackrec/trackrec.conf"
  [[ -f "$cfg" ]] || return 0

  local line
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^# ]] && continue
    if [[ "$line" =~ ^TRACKREC_[A-Z0-9_]+= ]]; then
      eval "$line"
    fi
  done < "$cfg"
}

need_cmd python3

TAGGER="$HOME/.local/bin/trackrec/trackrec-enrich-spot.py"

if [[ ! -x "$TAGGER" ]]; then
  if [[ -x "$(dirname "$0")/trackrec-enrich-spot.py" ]]; then
    TAGGER="$(dirname "$0")/trackrec-enrich-spot.py"
  elif command -v trackrec-enrich-spot.py >/dev/null 2>&1; then
    TAGGER="$(command -v trackrec-enrich-spot.py)"
  else
    echo "Missing command: trackrec-enrich-spot.py" >&2
    exit 3
  fi
fi

load_env
load_trackrec_conf

# Determine default recordings dir if no paths are given
default_outdir="${TRACKREC_OUTDIR:-}"

# expand ~ and $HOME
default_outdir="${default_outdir/#\~/$HOME}"
default_outdir="${default_outdir//\$HOME/$HOME}"

# fallback only if config not set
if [[ -z "$default_outdir" ]]; then
  [[ -d "$HOME/recordings" ]] && default_outdir="$HOME/recordings"
fi

# collect files from positional args (files/dirs), forward rest of flags
paths=()
forward=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0;;
    --*)
      forward+=("$1"); shift
      if [[ $# -gt 0 && "${forward[-1]}" =~ ^--spotify-client-(id|secret)$ ]]; then
        forward+=("${1:-}"); shift
      fi
      ;;
    *)
      paths+=("$1"); shift
      ;;
  esac
done

if [[ ${#paths[@]} -eq 0 ]]; then
  if [[ -z "$default_outdir" || ! -d "$default_outdir" ]]; then
    echo "ERROR: No input path given and no valid default found." >&2
    echo "Either:" >&2
    echo "  - pass a path to trackrec-enrich" >&2
    echo "  - or set TRACKREC_OUTDIR in ~/.config/trackrec/trackrec.conf" >&2
    exit 2
  fi
  paths+=("$default_outdir")
fi

files=()

add_file() {
  local f="$1"
  [[ -f "$f" ]] || return 0
  case "${f,,}" in
    *.flac|*.mp3|*.ogg|*.opus|*.m4a) files+=("$f");;
  esac
}

# expand paths
for p in "${paths[@]}"; do
  if [[ -d "$p" ]]; then
    while IFS= read -r -d '' f; do
      add_file "$f"
    done < <(find "$p" -type f \( -iname '*.flac' -o -iname '*.mp3' -o -iname '*.ogg' -o -iname '*.opus' -o -iname '*.m4a' \) -print0 | sort -z)
  else
    add_file "$p"
  fi
done

if [[ ${#files[@]} -eq 0 ]]; then
  echo "No supported audio files found in: ${paths[*]}" >&2
  exit 2
fi

exec "$TAGGER" "${files[@]}" "${forward[@]}"